{
	"schemaVersion": 1,
	"id": "axolotlclient",
	"version": "${version}",
	"name": "AxolotlClient",
	"description": "Free & Open-Source Minecraft Mod for use in PvP and other Scenarios",
	"authors": [
		"moehreag"
	],
	"contributors": [
		"YakisikliBaran",
		"DragonEggBedrockBreaking",
		"TheKodeToad",
		"CornetPanique86"
	],
	"contact": {
		"homepage": "https://axolotlclient.github.io/",
		"sources": "https://github.com/AxolotlClient/AxolotlClient-mod/",
		"issues": "https://github.com/AxolotlClient/AxolotlClient-mod/issues"
	},
	"license": "LGPL-3.0-or-later",
	"icon": "assets/axolotlclient/icon.png",
	"accessWidener": "axolotlclient.classtweaker",
	"environment": "client",
	"entrypoints": {
		"modmenu": [
			"io.github.axolotlclient.config.modmenu.ModMenuCompat"
		]
	},
	"mixins": [
		"axolotlclient.mixins.json",
		"axolotlclient-bridge.mixins.json",
		"axolotlclient.e4mc.mixins.json"
	],
	"custom": {
		"axolotlclient:bridge_impl_version": "V1_8"
	},
	"depends": {
		"fabricloader": ">=0.18.0",
		"minecraft": "1.8.9",
		"osl-resource-loader": "*",
		"osl-lifecycle-events": "*",
		"osl-keybinds": "*",
		"osl-entrypoints": "*",
		"axolotlclientconfig": "*",
		"axolotlclient-common": "*",
		"legacy-lwjgl3": ">=1.2.11"
	}
}
